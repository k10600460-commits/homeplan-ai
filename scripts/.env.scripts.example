# scripts/ 用 環境変数サンプル
# 本番 SplanAI の .env.local とは別ファイルで管理してください。
#
# 使い方:
#   cp scripts/.env.scripts.example scripts/.env.scripts
#   # .env.scripts に実際のキーを記入
#   PLACES_API_KEY=$(grep PLACES_API_KEY scripts/.env.scripts | cut -d= -f2) \
#     npx tsx scripts/fetch-builders.ts
#
# 詳細は scripts/README.md を参照。

# Google Places API (New) — 本番 SplanAI とは別の GCP プロジェクトのキー
PLACES_API_KEY=
